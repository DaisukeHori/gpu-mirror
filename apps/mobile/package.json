{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:release": "expo run:ios --configuration Release --no-bundler",
    "ios:release:device": "expo run:ios --configuration Release --device --no-bundler",
    "android:release": "expo run:android --variant release",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "echo 'lint:ok'"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@revol-mirror/shared": "*",
    "@supabase/supabase-js": "^2.99.2",
