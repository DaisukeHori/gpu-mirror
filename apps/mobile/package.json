    "react-native-webview": "13.16.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.11",
    "react-test-renderer": "^19.2.3",
