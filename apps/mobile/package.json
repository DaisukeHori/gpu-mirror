    "expo-auth-session": "~55.0.8",
    "expo-camera": "~55.0.10",
    "expo-constants": "~55.0.8",
    "expo-file-system": "~55.0.11",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-manipulator": "~55.0.11",
    "expo-image-picker": "~55.0.13",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.6",
    "expo-secure-store": "~55.0.9",
    "expo-sharing": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.10",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-css-interop": "^0.2.3",
